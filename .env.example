# Root .env, shared by every service in docker-compose.yml via `env_file: .env`.
# Copy this to `.env` (untracked) and fill in real values. Empty is fine for anything you
# aren't using yet — e.g. no NVIDIA_API_KEY means the influencer-agent container will start
# but fail when it actually tries to call the LLM.

# --- social_network ---
# The tuna company under study. Not hardcoded anywhere; everything derives from this.
COMPANY_NAME=HappyTuna
COMPANY_ALIASES=
PLATFORM_NAME=BrightTweets
CORS_ORIGIN=*
# Optional: turns on Claude-based sentiment analysis in social_network's analytics service.
AI_ANALYSIS_ENABLED=false
ANTHROPIC_API_KEY=

# --- influencer-agent ---
# NVIDIA NIM API key (get one at https://build.nvidia.com). Required unless you switch
# NAT_CONFIG_FILE to configs/config.openai.yml, in which case set OPENAI_API_KEY instead.
NVIDIA_API_KEY=
OPENAI_API_KEY=
