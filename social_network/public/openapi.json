          "201": { "description": "Comment created", "content": { "application/json": { "schema": { "type": "object", "properties": { "success": { "type": "boolean", "example": true }, "data": { "type": "object", "properties": { "comment": { "$ref": "#/components/schemas/Comment" } } } } } } } },
