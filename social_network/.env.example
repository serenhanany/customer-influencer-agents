DATABASE_URL=file:./dev.db
PORT=3000
NODE_ENV=development
CORS_ORIGIN=*

# The tuna company the platform's public opinion is measured about. The name is NOT hardcoded
# anywhere — detection and all UI labels derive from these. Set COMPANY_NAME to the real name
# when it is known (e.g. HappyTuna); no code changes needed.
COMPANY_NAME=HappyTuna
# Optional extra detection terms (alternate spellings / handles / cashtags), comma-separated.
# The company name itself (with and without spaces) is always matched; these are additions.
# COMPANY_ALIASES="happy tuna,$happy,#happytuna"
COMPANY_ALIASES=

# This product's own brand name (ours), shown in the UI.
PLATFORM_NAME=BrightTweets

# Default state of the AI sentiment toggle (can be flipped at runtime via /api/analytics/config).
AI_ANALYSIS_ENABLED=false

# Optional — used for AI sentiment analysis when the toggle is on.
# If unset (or the toggle is off), analytics use the deterministic lexicon scorer.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
