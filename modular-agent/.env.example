# --- Module 1: LLM ---
# provider: claude | gemini
LLM_PROVIDER=claude
# default model is the fast/cheap tier; bump to claude-sonnet-5 / claude-opus-4-8 as needed
LLM_MODEL=claude-haiku-4-5

# API keys (leave blank unless you have explicit permission to use a real key)
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# --- Module 2: MCP servers (used by examples/demo) ---
# From the host, the social-network compose service maps 3005:3000.
MCP_SOCIAL_URL=http://localhost:3005/mcp/social
MCP_ANALYTICS_URL=http://localhost:3005/mcp/analytics

# --- Module 5: token budget ---
AGENT_TOKEN_BUDGET=100000
AGENT_MAX_TOKENS=4096
